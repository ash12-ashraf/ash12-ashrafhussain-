!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>CoverForge · Cover Page Generator</title>
    <!-- Font Awesome Icons (free) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <!-- html2pdf library for PDF export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js" integrity="sha512-GsLlZN/3F2ErC5ifS5QtgpiJtWd43JWSuIgh7mbzZ8zBps+dvLusV+eNQATqgA/HdeKFVgA5v3S/cIrLF7QnIg==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        }

        body {
            background: linear-gradient(145deg, #eef2f9 0%, #d9e1ec 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 2rem 1rem;
        }

        .app {
            max-width: 1350px;
            width: 100%;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(8px);
            border-radius: 3rem;
            box-shadow: 0 30px 60px -15px rgba(0, 20, 40, 0.4);
            padding: 2rem 2rem 2.5rem;
            transition: all 0.3s ease;
            border: 1px solid rgba(255,255,255,0.6);
        }

        h1 {
            font-size: 1.8rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            display: flex;
            align-items: center;
            gap: 0.8rem;
            color: #0b1e33;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }
        h1 i {
            background: linear-gradient(135deg, #1e3a6f, #2b4f8a);
            color: white;
            padding: 0.4rem 0.8rem;
            border-radius: 1.2rem;
            font-size: 1.3rem;
            box-shadow: 0 4px 10px rgba(26,58,107,0.3);
        }
        h1 span {
            background: linear-gradient(135deg, #1a3a6b, #3a6b9f);
            color: white;
            font-size: 0.85rem;
            font-weight: 600;
            padding: 0.2rem 1.4rem;
            border-radius: 40px;
            margin-left: 0.3rem;
            letter-spacing: 0.02em;
            box-shadow: 0 2px 8px rgba(26,58,107,0.2);
        }

        .grid {
            display: grid;
            grid-template-columns: 1fr 1.2fr;
            gap: 2.5rem;
        }

        /* left panel – controls */
        .controls {
            background: rgba(255,255,255,0.7);
            backdrop-filter: blur(4px);
            padding: 1.8rem 2rem;
            border-radius: 2rem;
            border: 1px solid rgba(255,255,255,0.8);
            box-shadow: 0 8px 25px -8px rgba(0,0,0,0.08);
        }

        .control-group {
            margin-bottom: 1.2rem;
        }

        .control-group label {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-weight: 600;
            font-size: 0.8rem;
            color: #1f3a5f;
            letter-spacing: 0.02em;
            margin-bottom: 0.3rem;
        }
        .control-group label i {
            color: #2b4f8a;
            width: 1.3rem;
            font-size: 0.9rem;
        }

        input, select, textarea {
            width: 100%;
            padding: 0.6rem 1.1rem;
            background: white;
            border: 1px solid #dce1ec;
            border-radius: 1.2rem;
            font-size: 0.9rem;
            transition: 0.2s;
            color: #0b1e33;
            box-shadow: inset 0 1px 3px rgba(0,0,0,0.02);
        }
        input:focus, select:focus, textarea:focus {
            outline: 2px solid #1e3a6f;
            outline-offset: 2px;
            border-color: transparent;
            box-shadow: 0 4px 12px rgba(26, 58, 107, 0.12);
        }

        .color-row {
            display: flex;
            gap: 0.8rem;
            align-items: center;
        }
        .color-row input[type="color"] {
            width: 2.8rem;
            height: 2.8rem;
            padding: 0.1rem;
            border-radius: 1.2rem;
            cursor: pointer;
            border: 2px solid #d0d8e6;
            background: white;
        }
        .color-row input[type="text"] {
            flex: 1;
        }

        .row-2col {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.8rem;
        }

        .btn {
            background: white;
            border: 1px solid #d0d8e6;
            padding: 0.7rem 0;
            border-radius: 2.5rem;
            font-weight: 600;
            color: #1f3a5f;
            cursor: pointer;
            transition: 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.6rem;
            font-size: 0.9rem;
            box-shadow: 0 2px 6px rgba(0,0,0,0.02);
        }
        .btn i {
            font-size: 1rem;
        }
        .btn-primary {
            background: linear-gradient(135deg, #1e3a6f, #2b4f8a);
            border: none;
            color: white;
            box-shadow: 0 4px 12px rgba(26,58,107,0.3);
        }
        .btn-primary i {
            color: white;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(26,58,107,0.35);
        }
        .btn-outline {
            background: transparent;
            border: 1px solid #c9d2e3;
        }
        .btn-outline:hover {
            background: #eef2f9;
            border-color: #a0b0cc;
        }
        .btn-success {
            background: linear-gradient(135deg, #0f3b2e, #1a5a47);
            border: none;
            color: white;
            box-shadow: 0 4px 12px rgba(15,59,46,0.3);
        }
        .btn-success:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(15,59,46,0.35);
        }
        .btn-pdf {
            background: linear-gradient(135deg, #b22222, #8b0000);
            border: none;
            color: white;
            box-shadow: 0 4px 12px rgba(178,34,34,0.3);
        }
        .btn-pdf:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(178,34,34,0.35);
        }

        .action-bar {
            display: flex;
            gap: 0.8rem;
            margin-top: 1.8rem;
            flex-wrap: wrap;
        }
        .action-bar .btn {
            flex: 1;
            min-width: 100px;
        }

        /* right panel – preview */
        .preview {
            background: rgba(255,255,255,0.5);
            backdrop-filter: blur(4px);
            border-radius: 2rem;
            border: 1px solid rgba(255,255,255,0.8);
            padding: 1.6rem 1.8rem 1.8rem;
            display: flex;
            flex-direction: column;
            box-shadow: 0 8px 25px -8px rgba(0,0,0,0.06);
        }

        .preview-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.2rem;
        }
        .preview-header span {
            font-weight: 600;
            color: #1e3a6f;
            letter-spacing: 0.02em;
            font-size: 0.85rem;
            background: rgba(255,255,255,0.7);
            padding: 0.2rem 1.4rem;
            border-radius: 40px;
            backdrop-filter: blur(4px);
            border: 1px solid rgba(255,255,255,0.9);
        }

        .cover-container {
            background: rgba(242, 245, 252, 0.5);
            border-radius: 1.8rem;
            padding: 1rem;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 560px;
            transition: background 0.3s;
            backdrop-filter: blur(2px);
        }

        #cover {
            background: white;
            width: 100%;
            max-width: 460px;
            aspect-ratio: 0.85 / 1;
            border-radius: 1.8rem;
            box-shadow: 0 20px 40px -12px rgba(0, 20, 40, 0.25);
            display: flex;
            flex-direction: column;
            padding: 1.8rem 2rem 1.5rem;
            transition: background 0.3s, color 0.3s, border 0.3s;
            border: 1px solid rgba(255,255,255,0.5);
            position: relative;
            overflow: hidden;
            font-size: 0.85rem;
        }

        /* subtle decorative gradient overlay */
        #cover::before {
            content: '';
            position: absolute;
            top: -40%;
            right: -20%;
            width: 250px;
            height: 250px;
            background: radial-gradient(circle, rgba(255,255,255,0.05) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }

        /* Logo - clean shape extraction */
        .cover-logo {
            display: flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 0.3rem;
            position: relative;
            z-index: 1;
            min-height: 70px;
            background: transparent !important;
            padding: 0;
        }

        .cover-logo img {
            max-height: 70px;
            width: auto;
            max-width: 100%;
            object-fit: contain;
            display: block;
            background: transparent !important;
            background-color: transparent !important;
            filter: none !important;
            -webkit-filter: none !important;
            box-shadow: none !important;
            border: none !important;
            outline: none !important;
            mix-blend-mode: multiply;
        }

        .cover-logo img[src*=".png"],
        .cover-logo img[src*=".svg"] {
            mix-blend-mode: normal;
            background: transparent !important;
        }

        .cover-header {
            text-align: center;
            margin: 0.1rem 0 0.15rem;
            line-height: 1.5;
            position: relative;
            z-index: 1;
        }
        .cover-header .dept {
            font-weight: 700;
            font-size: 1rem;
            letter-spacing: 0.04em;
            opacity: 0.95;
            white-space: nowrap;
        }
        .cover-header .faculty {
            font-weight: 700;
            font-size: 0.75rem;
            opacity: 0.85;
            margin-top: -0.1rem;
        }
        .cover-header .semester {
            font-weight: 600;
            font-size: 0.7rem;
            opacity: 0.85;
        }
        .cover-header .assignment-label {
            font-weight: 800;
            font-size: 0.9rem;
            margin: 0.2rem 0 0.05rem;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            opacity: 0.9;
        }

        .cover-course {
            text-align: left;
            margin: 0.1rem 0 0.4rem;
            position: relative;
            z-index: 1;
            padding: 0 0.2rem;
        }
        .cover-course .title-line {
            display: flex;
            gap: 0.3rem;
            font-size: 0.8rem;
            line-height: 1.4;
        }
        .cover-course .title-line .label {
            font-weight: 700;
            opacity: 0.85;
            min-width: 5.5rem;
        }
        .cover-course .title-line .value {
            font-weight: 600;
            opacity: 0.95;
        }
        .cover-course .code-line {
            display: flex;
            gap: 0.3rem;
            font-size: 0.75rem;
            line-height: 1.4;
            margin-top: 0.05rem;
        }
        .cover-course .code-line .label {
            font-weight: 700;
            opacity: 0.85;
            min-width: 5.5rem;
        }
        .cover-course .code-line .value {
            font-weight: 600;
            opacity: 0.9;
        }

        /* elegant two-column info - ALL TEXT NOW BOLD */
        .cover-info {
            display: flex;
            gap: 1rem;
            margin: 0.3rem 0 0.5rem;
            padding: 0.6rem 0.4rem;
            border-top: 1.5px solid currentColor;
            border-bottom: 1.5px solid currentColor;
            opacity: 0.95;
            position: relative;
            z-index: 1;
        }
        .cover-info .col {
            flex: 1;
            font-size: 0.7rem;
            line-height: 1.8;
        }
        .cover-info .col .heading {
            font-weight: 800;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            opacity: 0.9;
            display: block;
            margin-bottom: 0.15rem;
        }
        /* ALL text in info columns are bold */
        .cover-info .col .label {
            font-weight: 700;
            opacity: 0.8;
            font-size: 0.6rem;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            display: inline-block;
            min-width: 4rem;
        }
        .cover-info .col .value {
            font-weight: 700;
            opacity: 0.95;
        }
        /* Student & Teacher names - extra bold */
        .cover-info .col .value-name {
            font-weight: 800;
            font-size: 0.75rem;
            opacity: 1;
        }
        .cover-info .col .teacher-details {
            display: block;
        }
        .cover-info .col .teacher-details .label {
            min-width: 4.5rem;
        }
        /* Department & University in Submitted By */
        .cover-info .col .student-dept-uni {
            display: block;
            font-size: 0.65rem;
            opacity: 0.95;
        }
        .cover-info .col .student-dept-uni .label {
            min-width: 4rem;
            font-weight: 700;
        }
        .cover-info .col .student-dept-uni .value {
            font-weight: 700;
        }
        /* Dept & Univ in Submitted To */
        .cover-info .col .dept-uni-line {
            display: block;
            font-size: 0.65rem;
            opacity: 0.95;
        }
        .cover-info .col .dept-uni-line .label {
            min-width: 4.5rem;
            font-weight: 700;
        }
        .cover-info .col .dept-uni-line .value {
            font-weight: 700;
        }

        .cover-footer {
            margin-top: 0.2rem;
            display: flex;
            justify-content: flex-end;
            font-size: 0.6rem;
            opacity: 0.7;
            padding-top: 0.4rem;
            border-top: 1px solid currentColor;
            position: relative;
            z-index: 1;
        }
        .cover-footer .date-only {
            font-weight: 600;
        }

        /* Responsive */
        @media (max-width: 920px) {
            .grid {
                grid-template-columns: 1fr;
                gap: 1.8rem;
            }
            .app {
                padding: 1.5rem;
            }
            #cover {
                max-width: 340px;
                margin: 0 auto;
            }
            .cover-header .dept {
                white-space: normal;
                font-size: 0.9rem;
            }
        }
        @media (max-width: 500px) {
            .row-2col {
                grid-template-columns: 1fr;
            }
            .action-bar {
                flex-direction: column;
            }
            #cover {
                font-size: 0.75rem;
                padding: 1.5rem;
            }
            .cover-info {
                flex-direction: column;
                gap: 0.2rem;
            }
            .cover-info .col {
                flex: 1 1 auto;
            }
            .cover-course .title-line,
            .cover-course .code-line {
                flex-wrap: wrap;
            }
            .cover-header .dept {
                white-space: normal;
                font-size: 0.85rem;
            }
            .cover-logo img {
                max-height: 50px;
            }
        }

        /* File input styling */
        .file-input-wrapper {
            display: flex;
            gap: 0.6rem;
            align-items: center;
            flex-wrap: wrap;
        }
        .file-input-wrapper input[type="file"] {
            flex: 1;
            padding: 0.4rem 0.6rem;
            border: 1px dashed #b0c0d8;
            border-radius: 1rem;
            background: rgba(255,255,255,0.5);
            font-size: 0.8rem;
            cursor: pointer;
        }
        .file-input-wrapper input[type="file"]::file-selector-button {
            padding: 0.3rem 1rem;
            border: none;
            border-radius: 2rem;
            background: linear-gradient(135deg, #1e3a6f, #2b4f8a);
            color: white;
            font-weight: 600;
            font-size: 0.7rem;
            cursor: pointer;
            margin-right: 0.8rem;
            transition: 0.2s;
        }
        .file-input-wrapper input[type="file"]::file-selector-button:hover {
            transform: scale(1.02);
            box-shadow: 0 2px 8px rgba(26,58,107,0.3);
        }

        .logo-hint {
            display: block;
            margin-top: 0.2rem;
            font-size: 0.65rem;
            color: #6b7d9a;
        }
        .logo-hint i {
            color: #c9a84c;
            margin-right: 0.3rem;
        }
    </style>
</head>
<body>

<div class="app">
    <h1>
        <i class="fas fa-pen-fancy"></i> CoverForge
        <span>All Bangladesh</span>
    </h1>

    <div class="grid">
        <!-- LEFT: controls -->
        <div class="controls">
            <div class="control-group" style="background:rgba(255,255,255,0.5); border-radius:1.2rem; padding:0.5rem 1rem; margin-bottom:1.2rem; border:1px solid rgba(255,255,255,0.8);">
                <div style="display:flex; align-items:center; gap:0.6rem; flex-wrap:wrap;">
                    <i class="fas fa-pen-fancy" style="font-size:1.6rem; color:#1e3a6f;"></i>
                    <div>
                        <div style="font-weight:700; font-size:0.8rem; color:#0b1e33;">CoverForge</div>
                        <div style="font-size:0.7rem; color:#2b4f8a; font-weight:500;">for all students in Bangladesh</div>
                    </div>
                </div>
            </div>

            <!-- Logo URL + File Upload -->
            <div class="control-group">
                <label><i class="fas fa-image"></i> Logo (Auto shape extraction)</label>
                <div class="file-input-wrapper">
                    <input type="text" id="logoUrl" value="https://sstu.ac.bd/logo.png" placeholder="Paste image URL" style="flex:2;">
                    <input type="file" id="logoFile" accept="image/*" style="flex:1;">
                </div>
                <small class="logo-hint">
                    <i class="fas fa-magic"></i> <strong>ONLY the logo shape will appear</strong> - backgrounds automatically removed
                </small>
            </div>

            <div class="control-group">
                <label><i class="fas fa-laptop-code"></i> Department Name</label>
                <input type="text" id="deptName" value="Department of Computer Science and Engineering" placeholder="e.g. Department of CSE">
            </div>

            <div class="control-group">
                <label><i class="fas fa-university"></i> Faculty Name</label>
                <input type="text" id="facultyName" value="Faculty of Engineering" placeholder="e.g. Faculty of Science">
            </div>

            <div class="control-group row-2col">
                <div>
                    <label><i class="fas fa-calendar-alt"></i> Semester</label>
                    <input type="text" id="semester" value="3rd" placeholder="e.g. 3rd">
                </div>
                <div>
                    <label><i class="fas fa-calendar-check"></i> Year</label>
                    <input type="text" id="year" value="2nd" placeholder="e.g. 2nd">
                </div>
            </div>

            <div class="control-group">
                <label><i class="fas fa-graduation-cap"></i> Program Name</label>
                <input type="text" id="programName" value="B.Sc. in CSE" placeholder="e.g. B.Sc. in CSE">
            </div>

            <div class="control-group">
                <label><i class="fas fa-tag"></i> Assignment Title</label>
                <input type="text" id="assignmentTitle" value="Vector Analysis, Complex Variables, Laplace Transform and Fourier Series" placeholder="Assignment title">
            </div>

            <div class="control-group">
                <label><i class="fas fa-code"></i> Course Code</label>
                <input type="text" id="courseCode" value="0541 04 MATH 2101" placeholder="Course code">
            </div>

            <div class="control-group">
                <label><i class="fas fa-user-graduate"></i> Student Name</label>
                <input type="text" id="studentName" value="Ashraf Hussain" placeholder="Full name">
            </div>

            <div class="control-group">
                <label><i class="fas fa-id-card"></i> Student ID</label>
                <input type="text" id="studentId" value="23240423" placeholder="ID">
            </div>

            <!-- Student's Department & University (Submitted By) -->
            <div class="control-group row-2col">
                <div>
                    <label><i class="fas fa-building"></i> Student's Department</label>
                    <input type="text" id="studentDept" value="Computer Science and Engineering" placeholder="e.g. CSE">
                </div>
                <div>
                    <label><i class="fas fa-university"></i> Student's University</label>
                    <input type="text" id="studentUni" value="Sunamganj Science and Technology University" placeholder="University name">
                </div>
            </div>

            <div class="control-group row-2col">
                <div>
                    <label><i class="fas fa-chalkboard-teacher"></i> Teacher Name</label>
                    <input type="text" id="teacherName" value="Dr. Mohammad Mobarak Hossain" placeholder="Course teacher">
                </div>
                <div>
                    <label><i class="fas fa-briefcase"></i> Designation</label>
                    <input type="text" id="designation" value="Professor" placeholder="Designation">
                </div>
            </div>

            <!-- Teacher's Department & University (Submitted To) -->
            <div class="control-group row-2col">
                <div>
                    <label><i class="fas fa-building"></i> Teacher's Department</label>
                    <input type="text" id="teacherDept" value="Mathematics" placeholder="e.g. Mathematics">
                </div>
                <div>
                    <label><i class="fas fa-university"></i> Teacher's University</label>
                    <input type="text" id="teacherUni" value="Sunamganj Science and Technology University" placeholder="University name">
                </div>
            </div>

            <div class="control-group">
                <label><i class="fas fa-calendar-alt"></i> Date of Submission</label>
                <input type="text" id="submissionDate" value="22/07/2026" placeholder="DD/MM/YYYY">
            </div>

            <div class="control-group row-2col">
                <div>
                    <label><i class="fas fa-palette"></i> Background</label>
                    <div class="color-row">
                        <input type="color" id="bgColor" value="#0b2a44">
                        <input type="text" id="bgColorText" value="#0b2a44" placeholder="#hex">
                    </div>
                </div>
                <div>
                    <label><i class="fas fa-font"></i> Text color</label>
                    <div class="color-row">
                        <input type="color" id="textColor" value="#f0f7ff">
                        <input type="text" id="textColorText" value="#f0f7ff" placeholder="#hex">
                    </div>
                </div>
            </div>

            <div class="control-group">
                <label><i class="fas fa-border-all"></i> Accent border</label>
                <div class="color-row">
                    <input type="color" id="accentColor" value="#c9a84c">
                    <input type="text" id="accentColorText" value="#c9a84c" placeholder="#hex">
                </div>
            </div>

            <div class="action-bar">
                <button class="btn btn-primary" id="applyBtn"><i class="fas fa-sync-alt"></i> Update</button>
                <button class="btn btn-pdf" id="pdfBtn"><i class="fas fa-file-pdf"></i> Download PDF</button>
                <button class="btn btn-outline" id="resetBtn"><i class="fas fa-undo-alt"></i> Reset</button>
            </div>
            <p style="font-size:0.7rem; color:#6b7d9a; margin-top: 1rem; text-align:center; border-top:1px solid #e0e6f0; padding-top:0.8rem;">
                <i class="fas fa-edit"></i> edit all fields · live preview
            </p>
        </div>

        <!-- RIGHT: preview -->
        <div class="preview">
            <div class="preview-header">
                <span><i class="fas fa-eye"></i> cover preview</span>
                <span style="background:transparent; font-size:0.8rem; color:#3b5b82;"><i class="fas fa-arrows-alt"></i> 0.85:1</span>
            </div>
            <div class="cover-container" id="coverContainer">
                <div id="cover">
                    <!-- Logo - ONLY the shape appears -->
                    <div class="cover-logo">
                        <img id="coverLogo" src="https://sstu.ac.bd/logo.png" alt="Logo" 
                             onerror="this.style.display='none';"
                             style="background:transparent !important; mix-blend-mode: multiply;">
                    </div>

                    <!-- Header - No separators -->
                    <div class="cover-header">
                        <div class="dept" id="previewDeptName">Department of Computer Science and Engineering</div>
                        <div class="faculty" id="previewFaculty">Faculty of Engineering</div>
                        <div class="semester" id="previewSemester">
                            Semester: <span id="previewSemesterVal">3rd</span> &nbsp; Year: <span id="previewYearVal">2nd</span> &nbsp; <span id="previewProgramVal">B.Sc. in CSE</span>
                        </div>
                        <div class="assignment-label">Assignment</div>
                    </div>

                    <!-- Course Title & Code -->
                    <div class="cover-course">
                        <div class="title-line">
                            <span class="label">Course Title :</span>
                            <span class="value" id="previewAssignmentTitle">Vector Analysis, Complex Variables, Laplace Transform and Fourier Series</span>
                        </div>
                        <div class="code-line">
                            <span class="label">Course Code :</span>
                            <span class="value" id="previewCourseCode">0541 04 MATH 2101</span>
                        </div>
                    </div>

                    <!-- Two-column info - ALL TEXT BOLD -->
                    <div class="cover-info">
                        <div class="col">
                            <span class="heading">Submitted By</span>
                            <span><span class="label">Name:</span> <span class="value value-name" id="previewStudent">Ashraf Hussain</span></span><br>
                            <span><span class="label">Student ID:</span> <span class="value" id="previewId">23240423</span></span><br>
                            <span class="student-dept-uni"><span class="label">Department:</span> <span class="value" id="previewStudentDept">Computer Science and Engineering</span></span>
                            <span class="student-dept-uni"><span class="label">University:</span> <span class="value" id="previewStudentUni">Sunamganj Science and Technology University</span></span>
                        </div>
                        <div class="col">
                            <span class="heading">Submitted To</span>
                            <span class="teacher-details"><span class="label">Teacher Name:</span> <span class="value value-name" id="previewTeacher">Dr. Mohammad Mobarak Hossain</span></span>
                            <span class="teacher-details"><span class="label">Designation:</span> <span class="value" id="previewDesignation">Professor</span></span>
                            <span class="dept-uni-line"><span class="label">Department:</span> <span class="value" id="previewTeacherDept">Mathematics</span></span>
                            <span class="dept-uni-line"><span class="label">University:</span> <span class="value" id="previewTeacherUni">Sunamganj Science and Technology University</span></span>
                        </div>
                    </div>

                    <!-- Footer - Signature removed, only date remains -->
                    <div class="cover-footer">
                        <span class="date-only" id="previewDate">Date: 22/07/2026</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        // DOM refs
        const logoUrl = document.getElementById('logoUrl');
        const logoFile = document.getElementById('logoFile');
        const deptName = document.getElementById('deptName');
        const facultyName = document.getElementById('facultyName');
        const semester = document.getElementById('semester');
        const year = document.getElementById('year');
        const programName = document.getElementById('programName');
        const assignmentTitle = document.getElementById('assignmentTitle');
        const courseCode = document.getElementById('courseCode');
        const studentName = document.getElementById('studentName');
        const studentId = document.getElementById('studentId');
        const studentDept = document.getElementById('studentDept');
        const studentUni = document.getElementById('studentUni');
        const teacherName = document.getElementById('teacherName');
        const designation = document.getElementById('designation');
        const teacherDept = document.getElementById('teacherDept');
        const teacherUni = document.getElementById('teacherUni');
        const submissionDate = document.getElementById('submissionDate');

        const bgColor = document.getElementById('bgColor');
        const bgColorText = document.getElementById('bgColorText');
        const textColor = document.getElementById('textColor');
        const textColorText = document.getElementById('textColorText');
        const accentColor = document.getElementById('accentColor');
        const accentColorText = document.getElementById('accentColorText');

        const coverLogo = document.getElementById('coverLogo');
        const previewDeptName = document.getElementById('previewDeptName');
        const previewFaculty = document.getElementById('previewFaculty');
        const previewSemesterVal = document.getElementById('previewSemesterVal');
        const previewYearVal = document.getElementById('previewYearVal');
        const previewProgramVal = document.getElementById('previewProgramVal');
        const previewAssignmentTitle = document.getElementById('previewAssignmentTitle');
        const previewCourseCode = document.getElementById('previewCourseCode');
        const previewStudent = document.getElementById('previewStudent');
        const previewId = document.getElementById('previewId');
        const previewStudentDept = document.getElementById('previewStudentDept');
        const previewStudentUni = document.getElementById('previewStudentUni');
        const previewTeacher = document.getElementById('previewTeacher');
        const previewDesignation = document.getElementById('previewDesignation');
        const previewTeacherDept = document.getElementById('previewTeacherDept');
        const previewTeacherUni = document.getElementById('previewTeacherUni');
        const previewDate = document.getElementById('previewDate');
        const cover = document.getElementById('cover');
        const coverContainer = document.getElementById('coverContainer');

        // sync color inputs
        function syncColorInputs(colorEl, textEl) {
            colorEl.addEventListener('input', () => {
                textEl.value = colorEl.value;
                applyCover();
            });
            textEl.addEventListener('input', () => {
                let val = textEl.value.trim();
                if (/^#[0-9a-fA-F]{6}$/.test(val)) {
                    colorEl.value = val;
                    applyCover();
                } else if (/^#[0-9a-fA-F]{3}$/.test(val)) {
                    const expanded = '#' + val[1]+val[1]+val[2]+val[2]+val[3]+val[3];
                    if (/^#[0-9a-fA-F]{6}$/.test(expanded)) {
                        colorEl.value = expanded;
                        textEl.value = expanded;
                        applyCover();
                    }
                }
            });
        }

        function updateLogo(src) {
            if (src && src.trim() !== '') {
                coverLogo.src = src.trim();
                coverLogo.style.display = 'block';
                coverLogo.style.background = 'transparent !important';
                coverLogo.style.backgroundColor = 'transparent !important';
                coverLogo.style.filter = 'none';
                coverLogo.style.webkitFilter = 'none';
                coverLogo.style.boxShadow = 'none';
                coverLogo.style.border = 'none';
                coverLogo.style.outline = 'none';
                
                const srcLower = src.toLowerCase();
                if (srcLower.includes('.png') || srcLower.includes('.svg')) {
                    coverLogo.style.mixBlendMode = 'normal';
                } else {
                    coverLogo.style.mixBlendMode = 'multiply';
                }
                
                coverLogo.onerror = function() {
                    this.style.display = 'none';
                };
            } else {
                coverLogo.style.display = 'none';
            }
        }

        function applyCover() {
            const url = logoUrl.value.trim();
            if (url) {
                updateLogo(url);
            } else {
                const file = logoFile.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function(e) {
                        updateLogo(e.target.result);
                    };
                    reader.onerror = function() {
                        coverLogo.style.display = 'none';
                    };
                    reader.readAsDataURL(file);
                } else {
                    updateLogo(null);
                }
            }

            previewDeptName.textContent = deptName.value || 'Department Name';
            previewFaculty.textContent = facultyName.value || 'Faculty Name';
            previewSemesterVal.textContent = semester.value || '—';
            previewYearVal.textContent = year.value || '—';
            previewProgramVal.textContent = programName.value || 'Program';
            previewAssignmentTitle.textContent = assignmentTitle.value || 'Assignment Title';
            previewCourseCode.textContent = courseCode.value || 'Course Code';
            previewStudent.textContent = studentName.value || '—';
            previewId.textContent = studentId.value || '—';
            previewStudentDept.textContent = studentDept.value || '—';
            previewStudentUni.textContent = studentUni.value || '—';
            previewTeacher.textContent = teacherName.value || '—';
            previewDesignation.textContent = designation.value || '—';
            previewTeacherDept.textContent = teacherDept.value || '—';
            previewTeacherUni.textContent = teacherUni.value || '—';
            previewDate.textContent = 'Date: ' + (submissionDate.value || 'DD/MM/YYYY');

            const bg = bgColor.value;
            const text = textColor.value;
            const accent = accentColor.value;

            cover.style.backgroundColor = bg;
            cover.style.color = text;
            cover.style.borderLeft = `6px solid ${accent}`;
            cover.style.borderRadius = '1.8rem';
            coverContainer.style.background = adjustBg(bg);
            
            const rgb = hexToRgb(bg);
            const luminance = (0.299 * rgb.r + 0.587 * rgb.g + 0.114 * rgb.b) / 255;
            
            if (coverLogo.src) {
                const src = coverLogo.src.toLowerCase();
                if (!src.includes('.png') && !src.includes('.svg')) {
                    if (luminance < 0.4) {
                        coverLogo.style.mixBlendMode = 'screen';
                    } else {
                        coverLogo.style.mixBlendMode = 'multiply';
                    }
                }
            }
        }
        
        function hexToRgb(hex) {
            const result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
            return result ? {
                r: parseInt(result[1], 16),
                g: parseInt(result[2], 16),
                b: parseInt(result[3], 16)
            } : { r: 0, g: 0, b: 0 };
        }

        function adjustBg(hex) {
            if (!hex) return '#f2f5fc';
            const r = parseInt(hex.slice(1,3), 16);
            const g = parseInt(hex.slice(3,5), 16);
            const b = parseInt(hex.slice(5,7), 16);
            const luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;
            if (luminance < 0.4) {
                const mix = (c) => Math.min(255, Math.floor(c + (255 - c) * 0.75));
                return `#${mix(r).toString(16).padStart(2,'0')}${mix(g).toString(16).padStart(2,'0')}${mix(b).toString(16).padStart(2,'0')}`;
            }
            return '#f2f5fc';
        }

        function resetToDefaults() {
            logoUrl.value = 'https://sstu.ac.bd/logo.png';
            logoFile.value = '';
            deptName.value = 'Department of Computer Science and Engineering';
            facultyName.value = 'Faculty of Engineering';
            semester.value = '3rd';
            year.value = '2nd';
            programName.value = 'B.Sc. in CSE';
            assignmentTitle.value = 'Vector Analysis, Complex Variables, Laplace Transform and Fourier Series';
            courseCode.value = '0541 04 MATH 2101';
            studentName.value = 'Ashraf Hussain';
            studentId.value = '23240423';
            studentDept.value = 'Computer Science and Engineering';
            studentUni.value = 'Sunamganj Science and Technology University';
            teacherName.value = 'Dr. Mohammad Mobarak Hossain';
            designation.value = 'Professor';
            teacherDept.value = 'Mathematics';
            teacherUni.value = 'Sunamganj Science and Technology University';
            submissionDate.value = '22/07/2026';
            bgColor.value = '#0b2a44';
            bgColorText.value = '#0b2a44';
            textColor.value = '#f0f7ff';
            textColorText.value = '#f0f7ff';
            accentColor.value = '#c9a84c';
            accentColorText.value = '#c9a84c';
            applyCover();
        }

        function exportPDF() {
            const element = document.getElementById('cover');
            const origBorderRadius = element.style.borderRadius;
            element.style.borderRadius = '0px';
            
            const opt = {
                margin:        [0, 0, 0, 0],
                filename:     'CoverForge_CoverPage.pdf',
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2, useCORS: true, allowTaint: false, logging: false },
                jsPDF:        { unit: 'px', format: [element.offsetWidth * 1.5, element.offsetHeight * 1.5], orientation: 'portrait' }
            };
            html2pdf().set(opt).from(element).save().then(() => {
                element.style.borderRadius = origBorderRadius;
            }).catch(() => {
                element.style.borderRadius = origBorderRadius;
            });
        }

        syncColorInputs(bgColor, bgColorText);
        syncColorInputs(textColor, textColorText);
        syncColorInputs(accentColor, accentColorText);

        logoUrl.addEventListener('input', applyCover);
        logoFile.addEventListener('change', applyCover);

        [deptName, facultyName, semester, year, programName, assignmentTitle, courseCode, studentName, studentId, studentDept, studentUni, teacherName, designation, teacherDept, teacherUni, submissionDate].forEach(input => {
            input.addEventListener('input', applyCover);
        });

        document.getElementById('applyBtn').addEventListener('click', applyCover);
        document.getElementById('resetBtn').addEventListener('click', resetToDefaults);
        document.getElementById('pdfBtn').addEventListener('click', exportPDF);

        applyCover();

        document.querySelectorAll('.color-row input[type="text"]').forEach(t => {
            t.addEventListener('blur', function() {
                const val = this.value.trim();
                if (/^#[0-9a-fA-F]{6}$/.test(val)) {
                    const colorInput = this.closest('.color-row').querySelector('input[type="color"]');
                    if (colorInput) colorInput.value = val;
                    applyCover();
                }
            });
        });

    })();
</script>

</body>
</html>
